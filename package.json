{
  "name": "karlhorning.dev",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate:posts": "tsx scripts/generate-posts-ts.ts",
    "build:posts": "tsx scripts/build-posts-json.ts",
    "build:rss": "tsx scripts/build-rss-from-posts.ts",
    "prebuild": "npm run generate:posts && npm run build:posts && npm run build:rss",
    "build": "next build",
    "start": "npx serve@latest out",
    "lint": "eslint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "check-links": "linkinator https://www.karlhorning.dev --recurse --skip '^mailto:' --timeout 10000",
    "check-links:local": "linkinator http://localhost:3000 --recurse --skip '^mailto:' --timeout 10000"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "fast-glob": "^3.3.3",
    "jsdom": "^27.0.1",
    "linkinator": "^7.6.1",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.6",
    "zod": "^4.3.6"
  }
}
